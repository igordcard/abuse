#pragma once
/* Generated by CMake from src/abuse_version.h.in. The string is computed
 * at configure time from `git describe --tags --long --match 'v*'` and is
 * baked into translation units via a header include rather than a
 * -D compile flag so that the default Makefile generator correctly
 * triggers recompilation whenever the version changes. */
#define PACKAGE_VERSION "@ABUSE_VERSION@"
